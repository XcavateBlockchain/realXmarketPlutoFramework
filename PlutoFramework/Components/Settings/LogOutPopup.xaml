<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlutoFramework.Components.Settings.LogOutPopup"
             xmlns:card="clr-namespace:PlutoFramework.Components.Card"
             xmlns:buttons="clr-namespace:PlutoFramework.Components.Buttons"
             IsVisible="{Binding IsVisible}"
             AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 1"
             AbsoluteLayout.LayoutFlags="All">

    <card:BottomPopupCard Title="Log out"
                          IsShown="{Binding IsVisible}">
        <card:BottomPopupCard.View>
            <AbsoluteLayout>

                <VerticalStackLayout AbsoluteLayout.LayoutBounds="0, 0, 1, AutoSize"
                                     AbsoluteLayout.LayoutFlags="WidthProportional"
                                     Spacing="20"
                                     Padding="20, 10, 20, 10">
                    <Label Text="Are you sure you want to log out?" />
                    <Label Text="This will delete all of your keys permanently from the device." />
                </VerticalStackLayout>

                <AbsoluteLayout AbsoluteLayout.LayoutBounds="0.5, 1, 1, 145"
                                AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional">

                    <Grid AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 115"
                          AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional"
                          ColumnSpacing="15"
                          RowSpacing="15"
                          Margin="10, 0, 10, 10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <buttons:ElevatedButton Text="Log out"
                                                Grid.Column="0"
                                                Grid.Row="0"
                                                Command="{Binding ContinueCommand}"
                                                ButtonState="Enabled"/>
                        <buttons:BasicGrayButton Text="Cancel"
                                                 Grid.Column="0"
                                                 Grid.Row="1"
                                                 Command="{Binding CancelCommand}"
                                                 ButtonState="Enabled"/>
                    </Grid>

                </AbsoluteLayout>

            </AbsoluteLayout>

        </card:BottomPopupCard.View>
    </card:BottomPopupCard>
</ContentView>
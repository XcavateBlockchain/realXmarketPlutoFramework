<?xml version="1.0" encoding="utf-8" ?>
<template:PageTemplate xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       xmlns:template="clr-namespace:PlutoFramework.Templates.PageTemplate"
                       x:Class="PlutoFramework.Components.Settings.LoggedOutPage"
                       Title="Logged out"
                       NavigationBarIsVisible="False">
    <AbsoluteLayout AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 1"
                    AbsoluteLayout.LayoutFlags="All">
        <VerticalStackLayout AbsoluteLayout.LayoutBounds="0.5, 0.5, 0.9, AutoSize"
                             AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional"
                             Spacing="10">
            <Label HorizontalTextAlignment="Center"
                   FontAttributes="Bold"
                   FontSize="24"
                   Text="Logged out" />
            <Label HorizontalTextAlignment="Center"
                   Text="Please restart the application to continue using it" />
        </VerticalStackLayout>
    </AbsoluteLayout>
</template:PageTemplate>
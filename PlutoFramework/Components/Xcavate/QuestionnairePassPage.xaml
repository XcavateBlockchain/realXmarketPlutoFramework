<?xml version="1.0" encoding="utf-8" ?>
<page:PageTemplate xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     x:Class="PlutoFramework.Components.Xcavate.QuestionnairePassPage"
                     xmlns:page="clr-namespace:PlutoFramework.Templates.PageTemplate"
                   xmlns:xcavate="clr-namespace:PlutoFramework.Components.Xcavate"
                     xmlns:hyperlink="clr-namespace:PlutoFramework.Components.Hyperlink"
                     Title="Questionnaire passed">
    <ScrollView AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 1"
            AbsoluteLayout.LayoutFlags="All">
        <VerticalStackLayout>
            <Label HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                LineBreakMode="WordWrap"
                Margin="30, 50, 30, 10"
                FontSize="20">
                <Label.FormattedText>
                    <FormattedString>
                        <Span FontAttributes="Bold"
                          Text="{Binding Text}"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                LineBreakMode="WordWrap"
                Margin="20, 50, 20, 20">
                <Label.FormattedText>
                    <FormattedString>
                        <hyperlink:Link Text="Terms and Conditions"
                                    Url="https://app.realxmarket.io/terms"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                LineBreakMode="WordWrap"
                Margin="20, 0, 20, 20">
                <Label.FormattedText>
                    <FormattedString>
                        <hyperlink:Link Text="Agreement"
                    Url="https://app.realxmarket.io/agreement"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                LineBreakMode="WordWrap"
                Margin="20, 0, 20, 20">
                <Label.FormattedText>
                    <FormattedString>
                        <hyperlink:Link Text="Privacy policy"
                            Url="https://app.realxmarket.io/privacy"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <HorizontalStackLayout HorizontalOptions="Center"
                               Spacing="5"
                               Margin="30, 0, 30, 10">

                <CheckBox IsChecked="{Binding TermsAgreed}"
                      VerticalOptions="Center" />

                <Label Text="I have read Terms and Conditions"
                   TextColor="Gray"
                   VerticalOptions="Center"/>

            </HorizontalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Center"
                               Spacing="5"
                               Margin="30, 0, 30, 10">

                <CheckBox IsChecked="{Binding AgreementAgreed}"
                      VerticalOptions="Center" />

                <Label Text="I have read Agreement"
                   TextColor="Gray"
                   VerticalOptions="Center"/>

            </HorizontalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Center"
                               Spacing="5"
                               Margin="30, 0, 30, 20">

                <CheckBox IsChecked="{Binding PrivacyPolicyAgreed}"
                      VerticalOptions="Center" />

                <Label Text="I have read Privacy policy"
                   TextColor="Gray"
                   VerticalOptions="Center"/>

            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

    <page:PageTemplate.PopupContent>
        <xcavate:PageBottomBarButtonView Text="Continue"
                                         ButtonState="{Binding ContinueButtonState}"
                                         Command="{Binding NavigateCommand}" />
    </page:PageTemplate.PopupContent>
</page:PageTemplate>
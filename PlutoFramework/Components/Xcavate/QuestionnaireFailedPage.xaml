<?xml version="1.0" encoding="utf-8" ?>
<page:PageTemplate xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:page="clr-namespace:PlutoFramework.Templates.PageTemplate"
                   xmlns:buttons="clr-namespace:PlutoFramework.Components.Buttons"
                   xmlns:xcavate="clr-namespace:PlutoFramework.Components.Xcavate"
             x:Class="PlutoFramework.Components.Xcavate.QuestionnaireFailedPage"
             Title="Questionnaire not passed">
    <ScrollView AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 1"
            AbsoluteLayout.LayoutFlags="All">
        <VerticalStackLayout>
            <Label HorizontalOptions="Center"
           HorizontalTextAlignment="Center"
           LineBreakMode="WordWrap"
           Margin="30, 50, 30, 10"
           FontSize="20">
                <Label.FormattedText>
                    <FormattedString>
                        <Span FontAttributes="Bold"
              Text="{Binding Title}"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap"
                   Margin="30, 0, 30, 20"
                   TextColor="#717171"
                   Text="{Binding Summary}" />

            <CollectionView ItemsSource="{Binding FailedSections}"
                            IsVisible="{Binding HasFailedSections}"
                            Margin="20, 0, 20, 20"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0, 8, 0, 8"
                                StrokeThickness="0"
                                BackgroundColor="#F5F5F5"
                                Padding="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       TextColor="#262626" />
                                <Label Text="{Binding Reason}"
                                       TextColor="#525252"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

    <page:PageTemplate.PopupContent>

        <xcavate:PageBottomBarView AbsoluteLayout.LayoutBounds="0.5, 1, 1, 90"
                               AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional"
                               RowSpacing="10"
                               >

            <xcavate:PageBottomBarView.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </xcavate:PageBottomBarView.ColumnDefinitions>
            
            <buttons:BasicGrayButton Text="Take me back"
                                    Margin="10"
                                     Command="{Binding CancelCommand}"/>
        </xcavate:PageBottomBarView>
    </page:PageTemplate.PopupContent>
</page:PageTemplate>
<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlutoFramework.Components.Nft.NftMultiImageView"
             xmlns:nft="clr-namespace:PlutoFramework.Components.Nft">
    <VerticalStackLayout Spacing="10">
        <nft:NftImageView x:Name="mainImage" />

        <CollectionView x:Name="thumbnailsCollectionView"
                        HeightRequest="60"
                        SelectionMode="Single"
                        SelectionChanged="OnThumbnailSelectionChanged"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never"
                        ItemSizingStrategy="MeasureFirstItem">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <nft:NftImageView WidthRequest="60"
                                      ExtraButtonsVisible="False"
                                      ImageSource="{Binding .}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>

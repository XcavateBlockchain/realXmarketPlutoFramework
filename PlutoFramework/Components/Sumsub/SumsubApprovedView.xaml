<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlutoFramework.Components.Sumsub.SumsubApprovedView"
             xmlns:card="clr-namespace:PlutoFramework.Components.Card">
    <card:Card VerticalOptions="Fill"
               BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B3B1B}">
        <VerticalStackLayout Spacing="8" Padding="16, 12, 16, 12">
            <!-- Status header -->
            <Label Text="Passed KYC verification"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#2E7D32, Dark=#66BB6A}"
                   HorizontalOptions="Fill"
                   HorizontalTextAlignment="Center" />

            <!-- Timestamp -->
            <Label x:Name="TimestampLabel"
                   Text="{Binding TimestampText}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasTimestamp}" />
        </VerticalStackLayout>
    </card:Card>
</ContentView>

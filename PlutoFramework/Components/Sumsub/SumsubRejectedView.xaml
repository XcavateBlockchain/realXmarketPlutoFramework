<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlutoFramework.Components.Sumsub.SumsubRejectedView"
             xmlns:card="clr-namespace:PlutoFramework.Components.Card">
    <card:Card VerticalOptions="Fill"
               BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3B1B1B}"
               BorderColor="{AppThemeBinding Light=#F44336, Dark=#C62828}"
               BorderWidth="2">
        <VerticalStackLayout Spacing="8" Padding="16, 12, 16, 12">
            <!-- Status header -->
            <Label Text="Verification Rejected"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#C62828, Dark=#EF5350}"
                   HorizontalOptions="Fill"
                   HorizontalTextAlignment="Center" />

            <!-- Reason -->
            <Label x:Name="ReasonLabel"
                   Text="{Binding Reason}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#424242, Dark=#BDBDBD}"
                   HorizontalOptions="Fill"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding ShowReason}" />

            <!-- Timestamp -->
            <Label x:Name="TimestampLabel"
                   Text="{Binding TimestampText}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasTimestamp}" />

            <!-- Attempts info -->
            <Label x:Name="AttemptsLabel"
                   Text="{Binding AttemptsText}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasAttempts}" />
        </VerticalStackLayout>
    </card:Card>
</ContentView>

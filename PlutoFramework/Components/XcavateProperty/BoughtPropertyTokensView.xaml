<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:card="clr-namespace:PlutoFramework.Components.Card"
             x:Class="PlutoFramework.Components.XcavateProperty.BoughtPropertyTokensView">
    <card:Card Margin="0">
        <card:Card.View>
            <AbsoluteLayout AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 70"
                    AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional">


                <StackLayout AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 70"
                AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional"
                >
                    <Label
                HeightRequest="30"
                VerticalTextAlignment="Center"
                HorizontalTextAlignment="Center"
                
                HorizontalOptions="Center"
                >
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="You bought" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Label HeightRequest="30"
                        VerticalTextAlignment="Center"
                        HorizontalTextAlignment="Center"
                        HorizontalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding TokensBought}"
                                  FontSize="20"
                                  FontAttributes="Bold"/>
                                <Span Text=" shares "
                                  FontSize="20"
                                  FontAttributes="Bold"/>
                                <Span Text="worth "/>

                                <Span Text="{Binding TokensBoughtWorth}"
                                  FontSize="20"
                                  FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </StackLayout>
            </AbsoluteLayout>
        </card:Card.View>
    </card:Card>
</ContentView>

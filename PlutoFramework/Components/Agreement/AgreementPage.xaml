<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                   xmlns:page="clr-namespace:PlutoFramework.Templates.PageTemplate"
                   xmlns:webview="clr-namespace:PlutoFramework.Components.WebView"
                   xmlns:xcavate="clr-namespace:PlutoFramework.Components.Xcavate"
                   xmlns:template="clr-namespace:PlutoFramework.Templates.TopNavigationBarTemplate"
                   x:Class="PlutoFramework.Components.Agreement.AgreementPage"
                   >
    <AbsoluteLayout AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 1"
                    AbsoluteLayout.LayoutFlags="All">

        <webview:PolkadotExtensionWebView x:Name="webView"
                                  AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, 1"
                                  AbsoluteLayout.LayoutFlags="All"
                                  Navigated="OnWebViewNavigated"
                                  Scrolled="OnWebViewScrolled"
                                  Source="{Binding Url}"
                                  Margin="0,0,0,70"
                                          TranslationY="-10"
                                  />

        <template:TopNavigationBarTemplate 
                    IsVisible="True"
                    Title="Agreement"/>
        
        <xcavate:PageBottomBarButtonView Text="{Binding AcceptButtonText}"
                                 ButtonState="{Binding AcceptButtonState}"
                                 Command="{Binding AcceptCommand}" />
    </AbsoluteLayout>
</ContentPage>